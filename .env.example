# Прямая строка подключения к PostgreSQL (используем существующий на сервере)
# Для локальной разработки DATABASE_URL не нужен — он строится из переменных ниже
DATABASE_URL=postgresql://ees_user:your_password@localhost:5432/ees_db

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=replace_with_random_64_char_hex

# Только для локальной разработки (docker-compose.yml без .prod)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb
