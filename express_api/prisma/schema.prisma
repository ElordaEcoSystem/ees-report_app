generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EXECUTOR
  MANAGER
  CUSTOMER
  ADMIN
  OBSERVER
}

enum RecordType {
  WORK
  DEFECT
  INSTALLATION
}

model Department {
  id       String    @id @default(uuid())
  code     String    @unique
  name     String
  users    User[]
  workLogs WorkLog[]
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  fullName     String?
  position     String?
  password     String
  role         Role        @default(EXECUTOR)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  workLogs      WorkLog[] @relation("AuthorWorkLogs") // как автор
  executingLogs WorkLog[] @relation("ExecutorsOnLogs") // как исполнитель
}

model WorkLog {
  id              String     @id @default(uuid())
  objectType      String?
  recordType      RecordType @default(WORK)
  object          String
  content         String
  photoUrls       String[]
  beforePhotoUrls String[]
  extraFields     Json       @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  authorId     String
  author       User        @relation("AuthorWorkLogs", fields: [authorId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  executors User[] @relation("ExecutorsOnLogs") // исполнители
}

